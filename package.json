{
  "name": "depshield-cli",
  "version": "0.1.0",
  "description": "Bootstrap safer JavaScript package-manager defaults for npm, pnpm and Bun projects.",
  "type": "module",
  "bin": {
    "depshield": "./bin/depshield.js"
  },
  "scripts": {
    "start": "node ./bin/depshield.js",
    "check": "node ./bin/depshield.js check --path .",
    "apply:dry": "node ./bin/depshield.js apply --path . --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
